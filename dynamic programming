def numberOfStableArrays(self, zero: int, one: int, limit: int) -> int:
        MOD = 10**9 + 7
        # dp[i][j][k] = ways using i zeros, j ones, last digit k
        # Recurrence (prefix sum trick):
        # dp[i][j][0] = dp[i-1][j][0] + dp[i-1][j][1] - (dp[i-1-limit][j][1] if i > limit else 0)
        # dp[i][j][1] = dp[i][j-1][1] + dp[i][j-1][0] - (dp[i][j-1-limit][0] if j > limit else 0)
        
        dp = [[[0, 0] for _ in range(one + 1)] for _ in range(zero + 1)]
        
        # Base: dp[i][0][0] = 1 for 1 <= i <= limit
        for i in range(1, min(zero, limit) + 1):
            dp[i][0][0] = 1
        # Base: dp[0][j][1] = 1 for 1 <= j <= limit
        for j in range(1, min(one, limit) + 1):
            dp[0][j][1] = 1
        
        for i in range(1, zero + 1):
            for j in range(1, one + 1):
                dp[i][j][0] = (dp[i-1][j][0] + dp[i-1][j][1]) % MOD
                if i > limit:
                    dp[i][j][0] = (dp[i][j][0] - dp[i-1-limit][j][1]) % MOD
                
                dp[i][j][1] = (dp[i][j-1][1] + dp[i][j-1][0]) % MOD
                if j > limit:
                    dp[i][j][1] = (dp[i][j][1] - dp[i][j-1-limit][0]) % MOD
        
        return (dp[zero][one][0] + dp[zero][one][1]) % MOD
